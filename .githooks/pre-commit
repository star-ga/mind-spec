#!/usr/bin/env bash
# arch-mind sidecar-scan on commit. Log-only (no regression gate yet).
# Self-contained: looks for arch-mind on PATH; silently no-ops if absent.
ARCH_MIND="$(command -v arch-mind 2>/dev/null)"
[ -z "$ARCH_MIND" ] || [ ! -x "$ARCH_MIND" ] && exit 0
mkdir -p .arch-mind
"$ARCH_MIND" sidecar-scan --repo . --out .arch-mind/last_summary.json >/dev/null 2>&1 || true
exit 0
